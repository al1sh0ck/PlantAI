# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://plantai:plantai@localhost:5432/plantai_db
POSTGRES_USER=plantai
POSTGRES_PASSWORD=plantai
POSTGRES_DB=plantai_db

# ── JWT (generate with: openssl rand -hex 32) ─────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML Model ──────────────────────────────────────────
MODEL_PATH=models/plantai_efficientnet_b0.pth
CLASS_NAMES_PATH=models/class_names.json

# ── App ───────────────────────────────────────────────
DEBUG=false
